tokens.db
active_tokens.json
trade_signals.json

# ── Backups (local safety copies) ─────────────────────────────
backups/

# ── Data directory (runtime) ──────────────────────────────────
data/

# ── Certs (NEVER commit TLS keys) ────────────────────────────
certs/

# ── Large reference docs (not part of the project) ────────────
openclaw_reference/

# ── Misc agent-generated content (not source code) ────────────
misc/

