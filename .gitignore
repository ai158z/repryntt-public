# ═══════════════════════════════════════════════════════════════
# repryntt .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/
*.whl

# ── Virtual environments ───────────────────────────────────────
.venv/
venv/
saige_venv/

# ── IDE / Editor ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Runtime data (regenerated on startup) ──────────────────────
logs/
*.log
brain/chains/
brain/conversations/
brain/autonomous_conversations/
brain/voices/audio_cache/
brain/llm_learning/
brain/cot_queue.json
brain/recent_grokipedia_searches.json
/memory/

# ── Agent workspaces (runtime data) ───────────────────────────
agent_workspaces/
repryntt/agents/agent_workspaces/
# Top-level runtime agents/ workspace (NOT the source agents package)
/agents/
repryntt/agents/brain/

# ── Runtime memory state (regenerated by daemon) ──────────────
brain/episodic_memory.json
brain/procedural_memory.json

# ── Test artifacts ────────────────────────────────────────────
