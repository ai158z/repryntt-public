# Repryntt install/runtime environment.
# Copy to .env for local development or pass these variables through your
# service manager, shell profile, Docker Compose, or hosting platform.

# Runtime data. Leave unset for the default ~/.repryntt on bare metal.
# REPRYNTT_DATA_DIR=/var/lib/repryntt

# AI provider used by the Python services.
REPRYNTT_PROVIDER=local
# REPRYNTT_API_KEY=
REPRYNTT_AGENT_NAME=Andrew
REPRYNTT_HEARTBEAT=69

# Global blockchain discovery. Fresh public installs follow the Bitcoin-style
# path: static/DNS seeds first, then peer gossip. HTTP bootstrap registries are
# optional self-hosted/community tools and are not required by default.
REPRYNTT_SEEDS=seed1.repryntt.ai158z.com:5001,seed2.repryntt.ai158z.com:5001
# REPRYNTT_BOOTSTRAP_URL=

# Set this on publicly reachable seed/full nodes so peers learn the right
# external address. Leave unset for private/local nodes.
# REPRYNTT_PUBLIC_P2P_ADDR=tcp://seed1.repryntt.ai158z.com:5001

# Rust chain defaults.
REPRYNTT_P2P_PORT=5001
REPRYNTT_RPC_BIND=127.0.0.1:9332
REPRYNTT_MINING=true
REPRYNTT_SKIP_IBD=false

# Robot hardware stack is off by default on non-robot hosts.
REPRYNTT_ENABLE_NAV=0
