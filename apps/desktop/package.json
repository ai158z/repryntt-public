{
  "name": "repryntt-desktop",
  "version": "0.1.0",
  "description": "The native desktop app for Repryntt — the autonomous, self-prompting AI agent you can actually own.",
  "main": "electron/main.cjs",
  "homepage": "https://www.repryntt.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/ai158z/repryntt-public.git",
    "directory": "apps/desktop"
  },
  "author": {
    "name": "repryntt",
    "email": "hello@ai158z.com"
  },
  "license": "AGPL-3.0-only",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder -mwl"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "electron-log": "^5.2.0"
  },
  "build": {
    "appId": "com.repryntt.desktop",
    "productName": "Repryntt",
    "copyright": "Copyright © 2026 Repryntt contributors",
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ai158z",
        "repo": "repryntt-public",
        "releaseType": "release"
      }
    ],
    "files": [
      "electron/**/*",
      "assets/**/*",
      "package.json",
      "node_modules/electron-updater/**/*",
      "node_modules/electron-log/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/lru-cache/**/*",
      "node_modules/sax/**/*",
      "node_modules/semver/**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme,*.flow,*.mk,test/**/*}"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "darkModeSupport": true
    },
    "dmg": {
      "title": "Repryntt ${version}",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "publisherName": "Repryntt"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Repryntt"
    },
    "linux": {
      "icon": "assets/icon.png",
      "category": "Development",
      "target": [
        { "target": "AppImage", "arch": ["x64", "arm64"] },
        { "target": "deb", "arch": ["x64", "arm64"] },
        { "target": "rpm", "arch": ["x64", "arm64"] }
      ],
      "maintainer": "hello@ai158z.com",
      "synopsis": "The autonomous AI agent you can actually own."
    }
  }
}
